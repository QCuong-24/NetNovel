POSTGRES_DB=netnovel
POSTGRES_USER=netnovel
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432

APP_PORT=8080
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=false

APP_JWT_SECRET=change-this-secret-before-deploying-netnovel
APP_JWT_ACCESS_TOKEN_EXPIRATION_SECONDS=183424400
APP_JWT_REFRESH_TOKEN_EXPIRATION_SECONDS=2324234234592000

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AUDIO_STORAGE_TYPE=LOCAL
AUDIO_STORAGE_PATH=storage/audio
AUDIO_DEFAULT_LANGUAGE_CODE=en-US
AUDIO_DEFAULT_VOICE_NAME=Joanna
AUDIO_DEFAULT_ENGINE=neural
AUDIO_DEFAULT_SPEAKING_RATE=1.00
AUDIO_DEFAULT_PITCH=0.00
AUDIO_DEFAULT_AUDIO_ENCODING=MP3
AUDIO_MAX_CHUNK_CHARACTERS=2800
AUDIO_MAX_TOTAL_CHARACTERS=50000
AUDIO_USER_MONTHLY_CHARACTER_QUOTA=100000
AUDIO_MANAGER_MONTHLY_CHARACTER_QUOTA=1000000
AUDIO_ADMIN_MONTHLY_CHARACTER_QUOTA=-1
AUDIO_CACHE_TTL_DAYS=30
APP_AUDIO_RABBIT_EXCHANGE=netnovel.audio
APP_AUDIO_RABBIT_GENERATION_QUEUE=audio.generation
APP_AUDIO_RABBIT_GENERATION_ROUTING_KEY=audio.generation

RABBITMQ_USER=netnovel
RABBITMQ_PASSWORD=change-me
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

SPRING_RABBITMQ_HOST=rabbitmq
SPRING_RABBITMQ_PORT=5672
SPRING_RABBITMQ_USERNAME=netnovel
SPRING_RABBITMQ_PASSWORD=change-me

APP_CRAWL_RABBIT_EXCHANGE=netnovel.crawl
APP_CRAWL_RABBIT_NOVEL_REQUEST_QUEUE=crawl.novel.request
APP_CRAWL_RABBIT_NOVEL_REQUEST_ROUTING_KEY=crawl.novel.request

# Format: sourceName|domain|JSOUP;sourceName2|domain2|PLAYWRIGHT
APP_CRAWLER_SUPPORTED_SOURCES=

APP_CRAWLER_PENDING_RECOVERY_ENABLED=true
APP_CRAWLER_PENDING_RECOVERY_DELAY_MS=60000
APP_CRAWLER_PENDING_RECOVERY_INITIAL_DELAY_MS=30000

ELASTIC_SEARCH_ENABLED=false
ELASTIC_SEARCH_URL=http://elasticsearch:9200
ELASTIC_SEARCH_NOVEL_INDEX=netnovel_novels
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_JAVA_OPTS=-Xms512m -Xmx512m

EMBEDDING_BASE_URL=http://embedding:8000
EMBEDDING_MODEL=intfloat/multilingual-e5-small

NOVEL_EMBEDDING_ENABLED=false
NOVEL_EMBEDDING_BASE_URL=http://embedding:8000
NOVEL_EMBEDDING_MODEL=intfloat/multilingual-e5-small
NOVEL_EMBEDDING_DIMENSION=384
NOVEL_EMBEDDING_REINDEX_BATCH_SIZE=16
NOVEL_EMBEDDING_TOP_K=10
NOVEL_EMBEDDING_MIN_SIMILARITY=0.0
NOVEL_EMBEDDING_FAIL_ON_INDEX_ERROR=false

CHATBOT_EMBEDDING_ENABLED=false
CHATBOT_EMBEDDING_DIMENSION=384
CHATBOT_EMBEDDING_TOP_K=5
CHATBOT_EMBEDDING_MIN_SIMILARITY=0.82
CHATBOT_EMBEDDING_REINDEX_BATCH_SIZE=16
